# =============================================================================
# Saaradhi — Root .env.example
# Copy to .env in each service directory and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (frontend/.env.local)
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL=https://api.saradhi.katakam.in
# VITE_GOOGLE_CLIENT_ID=your_google_client_id
# VITE_RAZORPAY_KEY_ID=your_razorpay_key
# VITE_APP_ENV=production

# -----------------------------------------------------------------------------
# BACKEND (backend/.env)
# -----------------------------------------------------------------------------
# PORT=5000
# NODE_ENV=production
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/saradhi?sslmode=require
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# SESSION_SECRET=a_long_random_string_for_user_sessions
# CALLBACK_URL=https://api.saradhi.katakam.in/api/auth/google/callback
# ANTHROPIC_API_KEY=your_anthropic_api_key
# CLAUDE_MODEL=claude-sonnet-4-6
# PYTHON_SERVICE_URL=http://localhost:8000
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# FRONTEND_URL=http://localhost:5173
# ADMIN_PASSWORD_HASH=generate_with_bcrypt
# ADMIN_SESSION_SECRET=another_long_random_string
# ADMIN_PORTAL_URL=http://localhost:5174

# -----------------------------------------------------------------------------
# ADMIN PORTAL (admin-portal/.env.local)
# -----------------------------------------------------------------------------
# VITE_ADMIN_API_URL=http://localhost:5000/admin/api

# -----------------------------------------------------------------------------
# PYTHON SERVICE (python-service/.env)
# -----------------------------------------------------------------------------
# NEWS_API_KEY=your_newsapi_key
# PORT=8000
# CACHE_TTL_SECONDS=3600
